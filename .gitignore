# Gradle files
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Local configuration file (sdk path, etc)
local.properties

# Android Studio
.idea/
*.iml
*.ipr
*.iws
.idea_modules/

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# OS-specific files
.DS_Store
Thumbs.db

# Log files
*.log

# Android Studio captures folder
captures/

# IntelliJ
out/

# Kotlin
*.kotlin_module

# OpenList data (may contain sensitive info)
app/src/main/jniLibs/

# Temporary files
*.tmp
*.temp
